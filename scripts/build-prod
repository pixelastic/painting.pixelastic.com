#!/usr/bin/env zsh
# Build the site for production with fingerprinting

# Initialize GVM
[[ -s ~/.gvm/scripts/gvm ]] && source ~/.gvm/scripts/gvm

# Stop on errors only once GVM is loaded
set -e

# Hugo build in production mode with integrated Tailwind CSS processing
# Hugo calls css.TailwindCSS function automatically during build
# Production mode enables fingerprinting for cache busting
hugo --minify --environment production
