#!/usr/bin/env zsh
# Run local development server with Tailwind watch

# Initialize GVM (Go Version Manager)
[[ -s ~/.gvm/scripts/gvm ]] && source ~/.gvm/scripts/gvm

set -e

echo "🚀 Starting Tailwind CSS watch & Hugo dev server..."

# Start Tailwind in watch mode in background
npx tailwindcss -i ./assets/css/main.css -o ./assets/css/style.css --watch &
TAILWIND_PID=$!

# Start Hugo server (this blocks)
hugo server --buildDrafts --buildFuture

# Clean up Tailwind process on exit
kill $TAILWIND_PID 2>/dev/null || true
