#!/usr/bin/env zsh
# Serve local website

# Initialize GVM
[[ -s ~/.gvm/scripts/gvm ]] && source ~/.gvm/scripts/gvm

# Stop on errors only once GVM is loaded
set -e

# Tailwind (watch mode in background with polling)
node_modules/.bin/tailwindcss \
  -i ./assets/src/style.css \
  -o ./assets/style.css \
  --watch \
  --poll &
TAILWIND_PID=$!

# Hugo dev server
hugo server \
  --buildDrafts \
  --buildFuture \
  --openBrowser

# Clean up Tailwind process on exit
kill $TAILWIND_PID 2>/dev/null || true
