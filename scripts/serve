#!/usr/bin/env bash
# Serve local website

# Load hugo from GVM if not available
if ! command -v hugo >/dev/null; then
  source "$HOME/.gvm/scripts/gvm" >/dev/null
fi

# Generate unique build ID for cache busting
export BUILD_ID=$(date +%s)

# Hugo dev server with integrated Tailwind CSS processing
hugo server \
  --buildDrafts \
  --buildFuture \
  --openBrowser
