#!/usr/bin/env zsh
# Install all dependencies (Hugo + npm)

# Initialize GVM (Go Version Manager)
[[ -s ~/.gvm/scripts/gvm ]] && source ~/.gvm/scripts/gvm

set -e

# Read Hugo version from netlify.toml (single source of truth)
HUGO_VERSION=$(rg 'HUGO_VERSION\s*=\s*"([^"]+)"' netlify.toml -o -r '$1')

echo "📦 Installing Hugo v${HUGO_VERSION}..."
go install github.com/gohugoio/hugo@v${HUGO_VERSION}
echo "✅ Hugo installed successfully!"
echo ""
hugo version
echo ""

echo "📦 Installing npm dependencies (Tailwind CSS)..."
yarn install
echo ""

echo "📦 Downloading Hugo modules..."
hugo mod get
echo ""

echo "✅ All dependencies installed!"
