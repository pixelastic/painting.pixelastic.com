#!/usr/bin/env zsh
set -e

# Note: Seems like the local aberlaas only compresses .png files.
# So I added this quick hack to also compress jpg files on commit.

# Get all staged files and filter for jpg files
stagedJpgs=($(git diff --cached --name-only | grep -i '\.jpg$'))

# Exit if no jpg files are staged
if [[ ${#stagedJpgs[@]} -eq 0 ]]; then
  echo "No jpg files in staging area"
  exit 0
fi

echo "Compressing ${#stagedJpgs[@]} jpg file(s)..."

# Run imgmin on each jpg file
for file in "${stagedJpgs[@]}"; do
  if [[ -f "$file" ]]; then
    echo "Compressing $file"
    imgmin "$file"
  fi
done

echo "Done!"
