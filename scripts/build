#!/usr/bin/env zsh
# Build the site locally

# Initialize GVM
[[ -s ~/.gvm/scripts/gvm ]] && source ~/.gvm/scripts/gvm

# Stop on errors only once GVM is loaded
set -e

# Build Tailwind first (scans layouts/ and content/)
node_modules/.bin/tailwindcss \
  -i ./assets/src/style.css \
  -o ./assets/style.css

# Build Hugo once with generated Tailwind CSS
hugo
